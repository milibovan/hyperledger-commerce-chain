{
  "namespace": "com.hyperledger_commerce_chain.streams.orders",
  "type": "record",
  "name": "OrderCreatedEvent",
  "doc": "This is schema for Order Created Event in streaming elt process",
  "fields": [
    {
      "name": "common",
      "type": "com.hyperledger_commerce_chain.streams.StreamsHeader"
    },
    {
      "name": "user_id",
      "type": "string"
    },
    {
      "name": "products",
      "type": {
        "type": "array",
        "items": {
          "type": "record",
          "name": "product",
          "fields": [
            { "name": "product_id", "type": "string" },
            { "name": "quantity", "type": "int" },
            { "name": "price", "type": "float" }
          ]
        }
      }
    },
    {
      "name": "total_cost",
      "type": "float"
    },
    {
      "name": "request_id",
      "type": "string",
      "default": ""
    }
  ]
}