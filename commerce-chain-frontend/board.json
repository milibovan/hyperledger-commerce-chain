  "phases": [
    {
      "id": 1,
      "name": "Foundation & Security",
      "weeks": "1-2",
      "status": "pending",
      "modules": [
        {
          "name": "Authentication Service",
          "days": "Week 1, Days 1-2",
          "tasks": [
            "Create new Rust workspace for microservices",
            "Initialize auth-service crate with Cargo",
            "Add dependencies: axum/actix-web, tokio, sqlx, jsonwebtoken, argon2, serde, validator, uuid, chrono",
            "Set up project structure (routes, handlers, models, utils)",
            "Configure environment variables (.env file)"
          ]
        },
        {
          "name": "Database & Models",
          "days": "Week 1, Days 3-4",
          "tasks": [
            "Provision PostgreSQL database",
            "Create schema: users (id, email, password_hash, full_name, role, is_verified, timestamps)",
            "Create schema: verification_tokens",
            "Create schema: refresh_tokens",
            "Write database migration scripts",
            "Implement database connection pool",
            "Create User model struct",
            "Create database repository layer"
          ]
        },
        {
          "name": "Core Authentication Logic",
          "days": "Week 1, Days 5-7",
          "tasks": [
            "Implement registration endpoint (validation, hash, create user, generate token)",
            "Implement login endpoint (validate creds, verify hash, generate JWT/refresh tokens)",
            "Implement JWT generation (claims: user_id, email, role, exp)",
            "Implement JWT validation (signature, expiry, claims extraction)",
            "Implement refresh token endpoint (validate and rotate tokens)"
          ]
        },
        {
          "name": "Email Verification & Password Mgmt",
          "days": "Week 2, Days 1-4",
          "tasks": [
            "Implement email verification endpoint",
            "Integrate email service (Kafka producer for email events)",
            "Implement forgot password endpoint (generate token, Kafka event)",
            "Implement reset password endpoint (validate token, update hash, revoke tokens)"
          ]
        },
        {
          "name": "API Gateway Service",
          "days": "Week 2, Days 5-7",
          "tasks": [
            "Create gateway-service crate",
            "Implement reverse proxy logic (hyper/reqwest)",
            "Implement Auth middleware (validate JWT, attach user ctx)",
            "Implement RBAC middleware (role checking)",
            "Implement Rate Limiting middleware (Redis backed)",
            "Implement Request Logging (stdout for Loki)",
            "Set up Redis connection pool"
          ]
        }
      ]
    },
